# ─── Kafka ───────────────────────────────────────────────────────────────────
# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Full DSN for the disaster-prediction PostgreSQL database
POSTGRES_URL=postgres://disaster_user:disaster_pass@localhost:5432/disaster_prediction?sslmode=disable

# ─── Sensor Ingestion (Task 2.1) ─────────────────────────────────────────────
# Comma-separated list of HTTP sensor feed endpoint URLs
SENSOR_FEED_URLS=http://sensor-feed-1.example.com/reading,http://sensor-feed-2.example.com/reading

# Poll interval in seconds (default: 900 = 15 minutes; must be ≤ 900)
SENSOR_POLL_INTERVAL_SECONDS=900

# ─── Data Validator (Task 2.3) ────────────────────────────────────────────────
# Kafka consumer group ID for the data validator
VALIDATOR_GROUP_ID=data-validator

# ─── Weather API Poller (Task 3.1) ───────────────────────────────────────────
# Comma-separated list of Weather API endpoint URLs
WEATHER_API_URLS=http://weather-api-1.example.com/forecast,http://weather-api-2.example.com/forecast

# Poll interval in seconds (default: 3600 = 1 hour; must be ≤ 3600)
WEATHER_POLL_INTERVAL_SECONDS=3600
